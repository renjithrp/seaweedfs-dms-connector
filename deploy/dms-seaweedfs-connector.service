[Unit]
Description=DMS SeaweedFS Connector
After=network.target
Wants=network.target

[Service]
Type=simple
User=seaweedfs
Group=seaweedfs
Environment=SEAWEEDFS_FILERS=http://10.5.93.213:8888,http://10.5.93.214:8888
Environment=LISTEN_ADDR=:9082
ExecStart=/usr/local/bin/dms-seaweedfs-connector
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
